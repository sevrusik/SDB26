{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdb26.com/schemas/l2e_fixture_schema_v0_1_0.json",
  "title": "SDB-26 L2E Fixture Schema v0.1.0",
  "description": "Fixture format for Level 2E post-processing/evasion corpus entries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "attack_level",
    "attack_stratum",
    "attack_subclass",
    "parent_id",
    "source_file",
    "derived_file",
    "transformation",
    "forensic_expectations",
    "ground_truth",
    "collected_at"
  ],
  "properties": {
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "attack_level": {
      "type": "string",
      "const": "L2"
    },
    "attack_stratum": {
      "type": "string",
      "const": "L2E"
    },
    "attack_subclass": {
      "type": "string",
      "enum": [
        "L2E1_CHROMA_REENCODE",
        "L2E2_AUTHENTIC_BLEND",
        "L2E3_FFT_ENVELOPE_TRANSPLANT",
        "L2E4_CFA_REMOSAIC",
        "L2E5_RELAUNDER_IMG2IMG"
      ]
    },
    "parent_id": {
      "type": "string",
      "description": "Identifier of pre-transform source artifact for lineage."
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "derived_file": {
      "type": "string",
      "minLength": 1
    },
    "transformation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["family"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "forensic_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sdb26_class", "attack_level"],
      "properties": {
        "sdb26_class": {
          "type": "string",
          "enum": ["SYNTHETIC", "EDITED", "SCREENSHOT", "INSUFFICIENT"]
        },
        "attack_level": {
          "type": "string",
          "const": "L2"
        }
      }
    },
    "collected_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
